{
	"schemaVersion": 1,
	"id": "hotchpotch",
	"version": "${project.version}",
	"name": "Hotchpotch",
	"description": "Just a hotchpotch of features I'd like when playing Minecraft.",
	"authors": [ "Chloe Arkwright" ],
	"contact": {
		"homepage": "https://modrinth.com/mod/hotchpotch",
		"sources": "https://github.com/chloe-arkwright/hotchpotch",
		"issues": "https://github.com/chloe-arkwright/hotchpotch/issues"
	},
	"license": "MIT",
	"icon": "assets/hotchpotch/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			{
				"value": "app.arkwright.hotchpotch.Hotchpotch",
				"adapter": "kotlin"
			}
		]
	},
	"mixins": [ "hotchpotch.mixins.json" ],
	"accessWidener": "hotchpotch.classTweaker",
	"depends": {
		"fabricloader": "${deps.fabric_loader}",
		"minecraft": "${deps.minecraft}",
		"java": "${deps.java}",
		"fabric-api": "${deps.fabric_api}",
		"fabric-language-kotlin": "${deps.fabric_kotlin}"
	}
}
